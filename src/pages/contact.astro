---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/globals.css';

const title = 'Contact Us | First Electrical Supply Inc.';
const description = 'Get in touch with First Electrical Supply. Call (416) 882-7070, email us, or visit our East York location. Same-day quotes for GTA contractors.';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://firstelectricalsupply.com/contact" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://firstelectricalsupply.com/contact" />
  <meta property="og:locale" content="en_CA" />
  <link rel="icon" type="image/png" href="/logo.png" />

  <!-- Async Google Fonts — no render-blocking -->
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" /></noscript>
</head>
<body>
  <Navbar />

  <main>
    <!-- Page hero -->
    <section class="relative overflow-hidden pt-36 pb-20" style="min-height: 420px;">
      <!-- Background image with Ken Burns animation -->
      <div class="absolute inset-0 z-0">
        <img
          id="hero-bg"
          src="https://images.unsplash.com/photo-1581094794329-c8112a89af12?w=1600&auto=format&fit=crop&q=80"
          alt=""
          class="w-full h-full object-cover"
          style="transform-origin: center center;"
        />
        <!-- Dark overlay -->
        <div class="absolute inset-0 bg-brand-navy/75"></div>
      </div>

      <!-- Content -->
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="inline-block text-brand-orange font-semibold text-sm uppercase tracking-widest mb-4">Get in Touch</span>
        <h1 class="text-4xl sm:text-5xl font-black text-white mb-5 leading-tight">
          We Actually Answer<br/>the Phone.
        </h1>
        <p class="text-white/60 text-lg max-w-xl mx-auto">
          Call, email, or walk in. Our team is ready to quote, confirm stock,
          and get your order moving — same business day.
        </p>
      </div>
    </section>

    <script>
      const bg = document.getElementById('hero-bg') as HTMLImageElement;
      const keyframes = [
        { transform: 'scale(1.08) translateX(1%)',  offset: 0   },
        { transform: 'scale(1.0)  translateX(-1%)', offset: 0.5 },
        { transform: 'scale(1.08) translateX(1%)',  offset: 1   },
      ];
      bg.animate(keyframes, { duration: 14000, iterations: Infinity, easing: 'ease-in-out' });
    </script>

    <!-- Contact details + form -->
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16 items-start">

          <!-- Left: contact info + map -->
          <div class="space-y-10">
            <!-- Info cards -->
            <div class="grid sm:grid-cols-2 gap-5">
              <a href="tel:+14168827070"
                class="group bg-white rounded-2xl border border-gray-100 p-6 shadow-sm hover:shadow-md hover:border-brand-orange/30 transition-all"
              >
                <div class="w-12 h-12 rounded-xl bg-brand-navy/5 flex items-center justify-center mb-4 group-hover:bg-brand-orange/10 transition-colors">
                  <svg class="w-6 h-6 text-brand-navy group-hover:text-brand-orange transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div class="text-xs text-gray-400 font-semibold uppercase tracking-widest mb-1">Phone</div>
                <div class="font-bold text-brand-navy text-lg group-hover:text-brand-orange transition-colors">(416) 882-7070</div>
                <div class="text-gray-400 text-sm mt-1">Mon–Fri 7am–5pm · Sat 8am–12pm</div>
              </a>

              <a href="mailto:info@firstelectricalsupply.com"
                class="group bg-white rounded-2xl border border-gray-100 p-6 shadow-sm hover:shadow-md hover:border-brand-orange/30 transition-all"
              >
                <div class="w-12 h-12 rounded-xl bg-brand-navy/5 flex items-center justify-center mb-4 group-hover:bg-brand-orange/10 transition-colors">
                  <svg class="w-6 h-6 text-brand-navy group-hover:text-brand-orange transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div class="text-xs text-gray-400 font-semibold uppercase tracking-widest mb-1">Email</div>
                <div class="font-bold text-brand-navy text-base group-hover:text-brand-orange transition-colors break-all">info@firstelectricalsupply.com</div>
                <div class="text-gray-400 text-sm mt-1">We reply same business day</div>
              </a>

              <a href="https://maps.app.goo.gl/Sntah1suZmvJnU629" target="_blank" rel="noopener noreferrer"
                class="group bg-white rounded-2xl border border-gray-100 p-6 shadow-sm hover:shadow-md hover:border-brand-orange/30 transition-all"
              >
                <div class="w-12 h-12 rounded-xl bg-brand-navy/5 flex items-center justify-center mb-4 group-hover:bg-brand-orange/10 transition-colors">
                  <svg class="w-6 h-6 text-brand-navy group-hover:text-brand-orange transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div class="text-xs text-gray-400 font-semibold uppercase tracking-widest mb-1">Location</div>
                <div class="font-bold text-brand-navy group-hover:text-brand-orange transition-colors">28 Industrial St, Unit 106</div>
                <div class="text-gray-500 text-sm">East York, ON M4G 1Y9</div>
              </a>

              <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
                <div class="w-12 h-12 rounded-xl bg-brand-navy/5 flex items-center justify-center mb-4">
                  <svg class="w-6 h-6 text-brand-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div class="text-xs text-gray-400 font-semibold uppercase tracking-widest mb-1">Hours</div>
                <div class="space-y-1 text-sm">
                  <div class="flex justify-between">
                    <span class="text-gray-500">Mon – Fri</span>
                    <span class="font-semibold text-brand-navy">7:00 AM – 5:00 PM</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-gray-500">Saturday</span>
                    <span class="font-semibold text-brand-navy">8:00 AM – 12:00 PM</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-gray-500">Sunday</span>
                    <span class="font-semibold text-gray-400">Closed</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Map -->
            <div class="rounded-2xl overflow-hidden border border-gray-200 shadow-sm">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2884.6!2d-79.3592126!3d43.7084496!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89d2cdce199a6b03%3A0x1ecd30d5999c7966!2s28+Industrial+St%2C+East+York%2C+ON+M4G+1Y9!5e0!3m2!1sen!2sca!4v1"
                width="100%"
                height="340"
                style="border:0;"
                allowfullscreen={false}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="First Electrical Supply location"
              ></iframe>
            </div>
          </div>

          <!-- Right: Quote form -->
          <div class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden sticky top-28">
            <div class="bg-brand-navy px-8 py-6">
              <h2 class="text-white font-bold text-2xl">Get a Free Quote</h2>
              <p class="text-white/60 text-sm mt-1">We respond same business day</p>
            </div>
            <div style="height: 660px; position: relative;">
              <iframe
                src="https://link.cicon.ca/widget/form/KtVDWCVcntC9jy3SWCqa"
                style="width:100%;height:100%;border:none;border-radius:0px"
                id="contact-form-embed"
                data-layout='{"id":"INLINE"}'
                data-trigger-type="alwaysShow"
                data-trigger-value=""
                data-activation-type="alwaysActivated"
                data-activation-value=""
                data-deactivation-type="neverDeactivate"
                data-deactivation-value=""
                data-form-name="Get a Free Quote"
                data-height="634"
                data-layout-iframe-id="contact-form-embed"
                data-form-id="KtVDWCVcntC9jy3SWCqa"
                title="Get a Free Quote"
              ></iframe>
              <script src="https://link.cicon.ca/js/form_embed.js" is:inline></script>
            </div>
          </div>

        </div>
      </div>
    </section>
  </main>

  <Footer />
</body>
</html>
