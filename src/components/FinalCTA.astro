<section class="py-24 bg-brand-navy relative overflow-hidden">
  <!-- Orange glow accent -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-brand-orange/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-72 h-72 bg-brand-orange/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-brand-orange/20 border border-brand-orange/30 text-brand-orange rounded-full px-5 py-2 text-sm font-semibold mb-8" data-reveal>
      East York, ON · Mon–Fri 7am–5pm · Sat 8am–12pm
    </div>

    <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.08] mb-6" data-reveal data-reveal-delay="1">
      Stop Mid-Job Supply Runs.<br/>
      <span class="text-brand-orange">Start Every Job Stocked.</span>
    </h2>

    <p class="text-white/60 text-xl leading-relaxed mb-10 max-w-2xl mx-auto" data-reveal data-reveal-delay="2">
      Open a trade account. Get wholesale pricing. Tell us what you need and we'll have it ready —
      pickup or free GTA delivery on orders over $1,000.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center" data-reveal data-reveal-delay="3">
      <a href="#quote" class="btn-primary text-lg px-10 py-4">
        Get a Free Quote
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
      <a href="tel:+14168827070" class="btn-outline text-lg px-10 py-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        (416) 882-7070
      </a>
    </div>

    <!-- Trust line -->
    <p class="text-white/30 text-sm mt-10" data-reveal data-reveal-delay="4">
      Serving the GTA for 20+ years · 5.0★ on Google · Independently owned and operated
    </p>
  </div>
</section>
