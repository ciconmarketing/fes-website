---
import { siteData } from '../lib/data';
const { testimonials, business } = siteData;
---

<section id="reviews" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12" data-reveal>
      <span class="section-tag">What our customers say</span>
      <p class="text-gray-500 text-lg max-w-xl mx-auto mt-4">
        Don't take our word for it. Here's what GTA electricians and contractors are saying.
      </p>
    </div>

    <!-- Google Review Placeholder -->
    <div class="mb-12 flex justify-center" data-reveal>
      <img
        src="/fes-google-review-placeholder.jpg"
        alt="First Electrical Supply Google Reviews"
        class="rounded-2xl shadow-md border border-gray-100 w-full max-w-[200px] h-auto object-cover"
        loading="lazy"
      />
    </div>

    <!-- Review cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      {testimonials.map((review, i) => (
        <div
          class="bg-gray-50 rounded-2xl p-8 border border-gray-100 card-hover relative"
          data-reveal
          data-reveal-delay={String((i % 2) + 1)}
        >
          <!-- Quote mark -->
          <div class="absolute top-6 right-8 text-brand-orange/20 text-7xl font-serif leading-none select-none">"</div>

          <!-- Stars (gold) -->
          <div class="flex text-yellow-400 text-xl mb-4">★★★★★</div>

          <!-- Review text -->
          <p class="text-gray-600 leading-relaxed mb-6 relative z-10">"{review.text}"</p>

          <!-- Meta -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-brand-navy/10 flex items-center justify-center font-bold text-brand-navy text-sm">
              {review.theme.charAt(0)}
            </div>
            <div>
              <div class="font-semibold text-brand-navy text-sm">Verified Google Review</div>
              <div class="text-gray-400 text-xs">{review.theme}</div>
            </div>
            <div class="ml-auto">
              <svg class="w-6 h-6" viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Overall badge -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-8 bg-brand-navy/5 rounded-2xl p-8" data-reveal>
      <div class="text-center">
        <div class="text-5xl font-black text-brand-navy">{business.googleRating}</div>
        <div class="flex text-yellow-400 text-2xl justify-center my-1">★★★★★</div>
        <div class="text-gray-500 text-sm">{business.reviewCount} total reviews</div>
      </div>
      <div class="hidden sm:block w-px h-16 bg-gray-200"></div>
      <div class="text-center sm:text-left">
        <p class="text-gray-600 text-lg max-w-xs leading-relaxed">
          "We truly appreciate the collaboration and look forward to continued success together."
        </p>
        <p class="text-gray-400 text-sm mt-2">— B2B Partner · Verified Review</p>
      </div>
      <div class="sm:ml-auto">
        <a
          href="https://maps.app.goo.gl/Sntah1suZmvJnU629"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-navy text-sm"
        >
          See All Google Reviews
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
