---
import { siteData } from '../lib/data';
const { hero, business } = siteData;

// Total frames extracted from video
const TOTAL_FRAMES = 60;
---

<section id="hero" class="relative w-full" style="height: 200vh;">
  <!-- Sticky canvas container -->
  <div id="hero-sticky" class="sticky top-0 h-screen w-full overflow-hidden">
    <!-- Static LCP image shown instantly before canvas is ready -->
    <img
      id="hero-lcp"
      src="/frames/frame001.jpg"
      alt=""
      fetchpriority="high"
      decoding="async"
      width="1440"
      height="810"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <!-- Canvas for scroll-driven frame sequence -->
    <canvas id="hero-canvas" class="absolute inset-0 w-full h-full" style="object-fit: cover; opacity: 0;"></canvas>

    <!-- Left-side navy gradient for text legibility only -->
    <div class="absolute inset-y-0 left-0 w-2/3 bg-gradient-to-r from-brand-navy/90 via-brand-navy/50 to-transparent pointer-events-none"></div>

    <!-- Hero Content -->
    <div class="relative z-10 h-full flex items-center">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="max-w-2xl">
          <!-- Badge -->
          <div id="hero-badge" class="inline-flex items-center gap-2 bg-brand-orange/20 border border-brand-orange/40 text-brand-orange rounded-full px-4 py-1.5 text-sm font-semibold mb-6 opacity-0">
            <span class="w-2 h-2 rounded-full bg-brand-orange animate-pulse"></span>
            East York, ON · Serving the GTA for 20+ Years
          </div>

          <!-- Headline -->
          <h1 id="hero-headline" class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.08] mb-6 opacity-0">
            {hero.headline}
          </h1>

          <!-- Subheadline -->
          <p id="hero-sub" class="text-lg sm:text-xl text-white/80 leading-relaxed mb-8 max-w-xl opacity-0">
            {hero.subheadline}
          </p>

          <!-- CTAs -->
          <div id="hero-ctas" class="flex flex-col sm:flex-row gap-4 opacity-0">
            <a href={hero.cta1.href} class="btn-primary text-base px-8 py-4">
              {hero.cta1.label}
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
            <a href={hero.cta2.href} class="btn-outline text-base px-8 py-4">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              {hero.cta2.label}
            </a>
          </div>

          <!-- Trust mini bar -->
          <div id="hero-trust" class="flex flex-wrap gap-6 mt-10 opacity-0">
            <div class="flex items-center gap-2 text-white/70 text-sm">
              <svg class="w-5 h-5 text-brand-orange" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              5.0 Google Rating · 19 Reviews
            </div>
            <div class="flex items-center gap-2 text-white/70 text-sm">
              <svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              Free GTA Delivery on $1,000+
            </div>
            <div class="flex items-center gap-2 text-white/70 text-sm">
              <svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              Mon–Fri 7am–5pm · Sat 8am–12pm
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div id="scroll-indicator" class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/50 text-xs font-medium opacity-0">
      <span>Scroll</span>
      <div class="w-px h-10 bg-gradient-to-b from-white/50 to-transparent animate-pulse"></div>
    </div>
  </div>
</section>

<script define:vars={{ TOTAL_FRAMES }}>
  const STEP = 2; // load every 2nd frame → 30 frames instead of 60
  const FRAME_COUNT = Math.ceil(TOTAL_FRAMES / STEP);

  const canvas  = document.getElementById('hero-canvas');
  const lcpImg  = document.getElementById('hero-lcp');
  const ctx     = canvas.getContext('2d');
  let frames       = [];
  let currentFrame = 0;
  let canvasReady  = false;

  function setCanvasSize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    if (canvasReady && frames[currentFrame]?.complete) drawFrame(currentFrame);
  }

  function drawFrame(index) {
    const img = frames[index];
    if (!img?.complete) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    const scaleW = canvas.width  / img.naturalWidth;
    const scaleH = canvas.height / img.naturalHeight;
    const scale  = Math.max(scaleW, scaleH * 0.55);
    const w = img.naturalWidth  * scale;
    const h = img.naturalHeight * scale;
    ctx.drawImage(img, (canvas.width - w) / 2, (canvas.height - h) / 2, w, h);
  }

  // Load frames after page load to not block LCP
  function loadFrames() {
    let loaded = 0;
    for (let i = 0; i < FRAME_COUNT; i++) {
      const frameNum = i * STEP + 1; // 1, 3, 5 … 59
      const img = new Image();
      img.src = `/frames/frame${String(frameNum).padStart(3, '0')}.jpg`;
      img.onload = () => {
        loaded++;
        if (loaded === 1) {
          // First frame ready — switch from static img to canvas
          setCanvasSize();
          drawFrame(0);
          canvas.style.opacity = '1';
          lcpImg.style.display = 'none';
          canvasReady = true;
        }
      };
      frames.push(img);
    }
  }

  // Defer frame loading until after page is interactive
  if (document.readyState === 'complete') {
    loadFrames();
  } else {
    window.addEventListener('load', loadFrames, { once: true });
  }

  window.addEventListener('resize', setCanvasSize);
  setCanvasSize();

  // Scroll-driven frame update
  const heroSection = document.getElementById('hero');
  window.addEventListener('scroll', () => {
    if (!canvasReady) return;
    const progress   = Math.max(0, Math.min(1, window.scrollY / (heroSection.offsetHeight - window.innerHeight)));
    const frameIndex = Math.min(Math.floor(progress * (FRAME_COUNT - 1)), FRAME_COUNT - 1);
    if (frameIndex !== currentFrame) {
      currentFrame = frameIndex;
      requestAnimationFrame(() => drawFrame(currentFrame));
    }
  });

  // Hero entrance animations
  const heroEls = {
    badge: document.getElementById('hero-badge'),
    headline: document.getElementById('hero-headline'),
    sub: document.getElementById('hero-sub'),
    ctas: document.getElementById('hero-ctas'),
    trust: document.getElementById('hero-trust'),
    scroll: document.getElementById('scroll-indicator'),
  };

  function animateIn(el, delay) {
    setTimeout(() => {
      el.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
      el.style.transform = 'translateY(0)';
      el.style.opacity = '1';
    }, delay);
  }

  // Set initial transform
  Object.values(heroEls).forEach(el => {
    if (el) el.style.transform = 'translateY(24px)';
  });

  animateIn(heroEls.badge, 300);
  animateIn(heroEls.headline, 500);
  animateIn(heroEls.sub, 700);
  animateIn(heroEls.ctas, 900);
  animateIn(heroEls.trust, 1100);
  animateIn(heroEls.scroll, 1400);
</script>
