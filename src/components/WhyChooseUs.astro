---
import { siteData } from '../lib/data';
const { whyUs } = siteData;

const iconPaths: Record<string, string> = {
  Phone: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
  Brain: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  Package: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  DollarSign: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  Store: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z',
  Zap: 'M13 10V3L4 14h7v7l9-11h-7z',
};
---

<section id="why-us" class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16" data-reveal>
      <span class="section-tag">Why contractors choose us</span>
      <h2 class="section-heading mb-4">The Supply House That<br/>Actually Has Your Back</h2>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto">
        We've heard it too: stock failures, staff who don't know the trade slang, prices that spike when supply gets tight.
        We built our operation around fixing exactly that.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {whyUs.map((item, i) => (
        <div
          class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 card-hover group"
          data-reveal
          data-reveal-delay={String((i % 3) + 1)}
        >
          <!-- Icon -->
          <div class="w-14 h-14 rounded-xl bg-brand-navy/5 flex items-center justify-center mb-6 group-hover:bg-brand-orange/10 transition-colors">
            <svg class="w-7 h-7 text-brand-navy group-hover:text-brand-orange transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[item.icon]}/>
            </svg>
          </div>
          <!-- Content -->
          <h3 class="text-xl font-bold text-brand-navy mb-3 group-hover:text-brand-orange transition-colors">{item.title}</h3>
          <p class="text-gray-500 leading-relaxed">{item.body}</p>
        </div>
      ))}
    </div>

    <!-- Bottom CTA strip -->
    <div class="mt-16 bg-brand-navy rounded-2xl p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-6" data-reveal>
      <div>
        <h3 class="text-2xl font-bold text-white mb-2">Still on the fence? Call us right now.</h3>
        <p class="text-white/60">Our counter staff is available Mon–Fri 7am–5pm · Sat 8am–12pm</p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 shrink-0">
        <a href="tel:+14168827070" class="btn-primary whitespace-nowrap">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          (416) 882-7070
        </a>
        <a href="#quote" class="btn-outline whitespace-nowrap">Get a Quote</a>
      </div>
    </div>
  </div>
</section>
