---

<section id="quote" class="py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <!-- Left: copy -->
      <div data-reveal>
        <span class="section-tag">Get a free quote</span>
        <h2 class="section-heading mb-6">
          Tell Us What You Need.<br/>
          <span class="text-brand-orange">We'll Handle the Rest.</span>
        </h2>
        <p class="text-gray-500 text-lg leading-relaxed mb-8">
          Fill out the form and our team will get back to you same business day with a quote,
          stock confirmation, and any alternatives we think you should know about.
        </p>

        <!-- Contact details -->
        <div class="space-y-5">
          <a href="tel:+14168827070" class="flex items-center gap-4 group">
            <div class="w-12 h-12 rounded-xl bg-brand-navy/5 flex items-center justify-center group-hover:bg-brand-orange/10 transition-colors">
              <svg class="w-6 h-6 text-brand-navy group-hover:text-brand-orange transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs text-gray-400 font-medium uppercase tracking-wide">Phone</div>
              <div class="font-semibold text-brand-navy group-hover:text-brand-orange transition-colors">(416) 882-7070</div>
            </div>
          </a>

          <a href="mailto:info@firstelectricalsupply.com" class="flex items-center gap-4 group">
            <div class="w-12 h-12 rounded-xl bg-brand-navy/5 flex items-center justify-center group-hover:bg-brand-orange/10 transition-colors">
              <svg class="w-6 h-6 text-brand-navy group-hover:text-brand-orange transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs text-gray-400 font-medium uppercase tracking-wide">Email</div>
              <div class="font-semibold text-brand-navy group-hover:text-brand-orange transition-colors">info@firstelectricalsupply.com</div>
            </div>
          </a>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-brand-navy/5 flex items-center justify-center">
              <svg class="w-6 h-6 text-brand-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs text-gray-400 font-medium uppercase tracking-wide">Location</div>
              <div class="font-semibold text-brand-navy">28 Industrial St, Unit 106, East York, ON M4G 1Y9</div>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-brand-navy/5 flex items-center justify-center">
              <svg class="w-6 h-6 text-brand-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs text-gray-400 font-medium uppercase tracking-wide">Hours</div>
              <div class="font-semibold text-brand-navy">Mon–Fri 7am–5pm · Sat 8am–12pm</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: GHL Form embed -->
      <div
        class="bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden"
        data-reveal
        data-reveal-delay="2"
      >
        <div class="bg-brand-navy px-8 py-5">
          <h3 class="text-white font-bold text-xl">Get a Free Quote</h3>
          <p class="text-white/60 text-sm mt-1">We respond same business day</p>
        </div>
        <div style="height: 660px; position: relative;">
          <iframe
            src="https://link.cicon.ca/widget/form/KtVDWCVcntC9jy3SWCqa"
            style="width:100%;height:100%;border:none;border-radius:0px"
            id="inline-KtVDWCVcntC9jy3SWCqa"
            data-layout='{"id":"INLINE"}'
            data-trigger-type="alwaysShow"
            data-trigger-value=""
            data-activation-type="alwaysActivated"
            data-activation-value=""
            data-deactivation-type="neverDeactivate"
            data-deactivation-value=""
            data-form-name="Get a Free Quote"
            data-height="634"
            data-layout-iframe-id="inline-KtVDWCVcntC9jy3SWCqa"
            data-form-id="KtVDWCVcntC9jy3SWCqa"
            title="Get a Free Quote"
          ></iframe>
          <script src="https://link.cicon.ca/js/form_embed.js" is:inline></script>
        </div>
      </div>
    </div>
  </div>
</section>
