---
import { siteData } from '../lib/data';
const { trustSignals, business } = siteData;

// Parse each value into countable parts
const parsed = trustSignals.map(s => {
  const num = parseFloat(s.value);
  const isNum = !isNaN(num);
  const suffix = isNum ? s.value.replace(/^[\d.]+/, '') : '';
  const decimals = isNum && s.value.includes('.') ? 1 : 0;
  return { ...s, isNum, num, suffix, decimals };
});
---

<section class="bg-brand-navy py-8 border-b border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-0 lg:divide-x lg:divide-white/20">
      {parsed.map((signal, i) => (
        <div
          class="flex flex-col items-center text-center px-4 py-2"
          data-reveal
          data-reveal-delay={String(i + 1)}
        >
          {signal.isNum ? (
            <span
              class="count-num text-3xl lg:text-4xl font-black text-brand-orange mb-1"
              data-count-to={signal.num}
              data-suffix={signal.suffix}
              data-decimals={signal.decimals}
              data-delay={String(i * 150)}
            >
              0{signal.suffix}
            </span>
          ) : signal.value === 'Free' ? (
            <span
              class="count-down-free text-3xl lg:text-4xl font-black text-brand-orange mb-1"
              data-delay={String(i * 150)}
            >
              $100
            </span>
          ) : (
            <span class="text-3xl lg:text-4xl font-black text-brand-orange mb-1">
              {signal.value}
            </span>
          )}
          <span class="text-white font-semibold text-sm lg:text-base">{signal.label}</span>
          <span class="text-white/50 text-xs mt-0.5">{signal.sub}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Google Reviews bar -->
<div class="bg-white border-b border-gray-100 py-3">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-wrap items-center justify-center gap-3">
    <span class="flex items-center gap-1.5 text-sm text-gray-600 font-medium">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      <span class="font-bold text-gray-800">5.0</span>
      <span class="flex text-yellow-400">★★★★★</span>
      <span class="text-gray-500">— {business.reviewCount} Google Reviews</span>
    </span>
    <span class="text-gray-300">|</span>
    <span class="text-sm text-gray-600 font-medium">⚡ Independently owned & operated in East York, ON</span>
    <span class="text-gray-300">|</span>
    <span class="text-sm text-gray-600 font-medium">✓ Walk-ins welcome · No trade account required</span>
  </div>
</div>
